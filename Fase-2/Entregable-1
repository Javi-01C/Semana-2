#include <iostream>
#include <stdexcept>

class ArregloDinamico {
private:
    int* datos;      
    int tamano;      
    int capacidad;   

    void redimensionar() {
        this->capacidad *= 2;
        int* nuevoArreglo = new int[this->capacidad]; 
        
        for (int i = 0; i < this->tamano; i++) {
            nuevoArreglo[i] = this->datos[i];
        }
        
        delete[] this->datos; 
        this->datos = nuevoArreglo; 
        
        // Un print para que VEAS cuándo ocurre la magia
        std::cout << "  [!] Redimensionando memoria... Nueva capacidad: " << this->capacidad << std::endl;
    }

public:
    ArregloDinamico(int capacidadInicial) {
        if (capacidadInicial <= 0) {
            throw std::invalid_argument("La capacidad debe ser mayor a 0");
        }
        this->capacidad = capacidadInicial;
        this->tamano = 0;
        this->datos = new int[this->capacidad]; 
    }

    ~ArregloDinamico() {
        delete[] this->datos; 
    }

    void agregar(int elemento) {
        if (this->tamano == this->capacidad) {
            redimensionar();
        }
        this->datos[this->tamano] = elemento;
        this->tamano++;
    }

    void insertar(int indice, int elemento) {
        if (indice < 0 || indice > this->tamano) {
            throw std::out_of_range("Índice fuera de rango");
        }
        if (this->tamano == this->capacidad) {
            redimensionar();
        }
        for (int i = this->tamano; i > indice; i--) {
            this->datos[i] = this->datos[i - 1];
        }
        this->datos[indice] = elemento;
        this->tamano++;
    }

    int eliminar(int indice) {
        if (indice < 0 || indice >= this->tamano) {
            throw std::out_of_range("Índice fuera de rango");
        }
        int elementoEliminado = this->datos[indice];
        
        for (int i = indice; i < this->tamano - 1; i++) {
            this->datos[i] = this->datos[i + 1];
        }
        this->tamano--;
        return elementoEliminado;
    }

    int obtener(int indice) {
        if (indice < 0 || indice >= this->tamano) {
            throw std::out_of_range("Índice fuera de rango");
        }
        return this->datos[indice];
    }

    int longitud() {
        return this->tamano;
    }
};


int main() {
    try {
        std::cout << "1. Creando arreglo con capacidad inicial de 2..." << std::endl;
        ArregloDinamico miArreglo(2); 
        
        std::cout << "Agregando 10..." << std::endl;
        miArreglo.agregar(10);
        std::cout << "Agregando 20..." << std::endl;
        miArreglo.agregar(20);
        
        std::cout << "Agregando 30... (Deberia forzar redimensionamiento a 4)" << std::endl;
        miArreglo.agregar(30); 
        
        std::cout << "\n2. Mostrando contenido actual:" << std::endl;
        for(int i = 0; i < miArreglo.longitud(); i++) {
            std::cout << "   Indice [" << i << "] = " << miArreglo.obtener(i) << std::endl;
        }
        
        std::cout << "\n3. Insertando el valor 15 en el indice 1..." << std::endl;
        miArreglo.insertar(1, 15);
        
        for(int i = 0; i < miArreglo.longitud(); i++) {
            std::cout << "   Indice [" << i << "] = " << miArreglo.obtener(i) << std::endl;
        }
        
    } catch (const std::exception& e) {
        std::cerr << "Error crítico: " << e.what() << std::endl;
    }
    
    return 0;
}






